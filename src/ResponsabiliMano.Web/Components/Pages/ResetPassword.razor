@page "/reset-password"
@attribute [AllowAnonymous]
@inject IPasswordResetService ResetService
@inject NavigationManager Navigation
@inject IStringLocalizer<AppStrings> Localizer

<PageTitle>@Localizer["ResetPasswordTitle"]</PageTitle>

<h3>@Localizer["ResetPasswordTitle"]</h3>

@if (_success)
{
    <div class="alert alert-success" role="alert">@Localizer["ResetPasswordSuccess"]</div>
    <p><a href="/login">@Localizer["BackToLogin"]</a></p>
}
else
{
    <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="resetPasswordForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="password" class="form-label">@Localizer["NewPasswordLabel"]</label>
            <InputText id="password" type="password" class="form-control" @bind-Value="_model.Password" />
            <ValidationMessage For="@(() => _model.Password)" />
        </div>

        <div class="mb-3">
            <label for="confirmPassword" class="form-label">@Localizer["ConfirmPasswordLabel"]</label>
            <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="_model.ConfirmPassword" />
            <ValidationMessage For="@(() => _model.ConfirmPassword)" />
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger" role="alert">@_error</div>
        }

        <button type="submit" class="btn btn-primary" disabled="@_isLoading">
            @(_isLoading ? Localizer["Resetting"] : Localizer["ResetPasswordButton"])
        </button>
    </EditForm>
}

@code {
    private ResetPasswordRequest _model = new();
    private string? _error;
    private bool _isLoading;
    private bool _success;

    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Token))
        {
            _model.Token = Token;
        }
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _error = null;

        try
        {
            var result = await ResetService.ResetPasswordAsync(_model.Token, _model.Password);
            if (result)
            {
                _success = true;
            }
            else
            {
                _error = Localizer["ResetPasswordInvalidToken"];
            }
        }
        catch (Exception)
        {
            _error = Localizer["ResetPasswordError"];
        }
        finally
        {
            _isLoading = false;
        }
    }
}
