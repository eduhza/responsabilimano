@page "/"
@attribute [Authorize]
@inject IStringLocalizer<AppStrings> Localizer

<PageTitle>@Localizer["HomeTitle"]</PageTitle>

<AuthorizeView>
    <Authorized>
        <h1>@Localizer["HomeWelcome", context.User.Identity?.Name ?? string.Empty]</h1>
        <p>@Localizer["EmailLabel"]: @context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</p>
    </Authorized>
</AuthorizeView>
