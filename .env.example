# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# Used by docker-compose.yml.

# Set to Development only for local development. Never in a deployed/public environment,
# as Development mode exposes detailed error pages and seeds demo accounts.
ASPNETCORE_ENVIRONMENT=Production

POSTGRES_USER=postgres
POSTGRES_DB=responsabilimano
# Required. Use a strong, unique value.
POSTGRES_PASSWORD=change-me
